# Copy this to `env.local` (gitignored) and fill in your site-specific values.
# `bootstrap.sh` sources this file. Anything secret or company-specific lives
# here, never in the committed repo.

# --- Corporate proxy ---------------------------------------------------------
# Leave empty / comment out if you are not behind a proxy.
export http_proxy="http://proxy.corp.example:8080"
export https_proxy="${http_proxy}"
export all_proxy="${http_proxy}"
export no_proxy="localhost,127.0.0.1,::1,.corp.example"
# Some tools read the uppercase variants; mirror them.
export HTTP_PROXY="${http_proxy}"
export HTTPS_PROXY="${https_proxy}"
export ALL_PROXY="${all_proxy}"
export NO_PROXY="${no_proxy}"

# --- Corporate root CA (TLS interception) ------------------------------------
# Path to your company's root CA in PEM format. bootstrap installs it into the
# system trust store so mise / git / curl / node stop failing with
# `UnknownIssuer`. Leave empty if your proxy does not intercept TLS.
CORP_CA_PEM=""
# e.g. CORP_CA_PEM="$HOME/corp-root-ca.pem"

# --- Company git identity ----------------------------------------------------
# Written to ~/.gitconfig.local (NOT the repo) and included by the committed
# gitconfig. user.name stays "akira"; only the email differs at work.
GIT_COMPANY_EMAIL="you@company.example"
